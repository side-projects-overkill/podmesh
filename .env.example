# PodMesh Server
PODMESH__HOST=0.0.0.0
PODMESH__PORT=8090
PODMESH__CORS_ORIGIN=http://localhost:3000

# PodMesh Agent
PODMESH_AGENT_ADDR=0.0.0.0:8091
PODMESH_PODMAN_SOCKET=/run/podman/podman.sock
PODMESH_SERVER_URL=http://localhost:8090
PODMESH_NODE_NAME=node-1

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8090
NEXT_PUBLIC_WS_URL=ws://localhost:8090/ws/events
