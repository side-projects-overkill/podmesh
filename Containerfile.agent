FROM rust:1.83-slim AS builder

WORKDIR /build
COPY Cargo.toml Cargo.lock ./
COPY crates/ crates/

RUN cargo build --release -p podmesh-agent

FROM debian:bookworm-slim

RUN apt-get update && apt-get install -y ca-certificates && rm -rf /var/lib/apt/lists/*

COPY --from=builder /build/target/release/podmesh-agent /usr/local/bin/

EXPOSE 8091

ENTRYPOINT ["podmesh-agent"]
